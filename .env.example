# Database
MONGODB_URI=mongodb+srv://your_username:your_password@cluster.mongodb.net/fam_bottling

# JWT
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production

# Server
PORT=5000
NODE_ENV=development
# Frontend URL (for CORS and machine redirects)
MACHINE_URL=http://localhost:3000

# ML Service URL (for AI bottle scanning)
ML_SERVICE_URL=http://localhost:5001

# Email Configuration (optional - for nodemailer)
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_specific_password

# Production Deployment Notes:
# When deploying to Vercel, ensure these are set in Vercel Dashboard:
# - MONGODB_URI: Your MongoDB Atlas connection string
# - JWT_SECRET: A strong, random string (minimum 32 characters)
# - MACHINE_URL: https://fam-bottling.vercel.app
# - ML_SERVICE_URL: https://fam-bottling-ml.onrender.com (if using separate ML service)